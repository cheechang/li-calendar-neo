{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "liCalendar",
  "mainBinaryName": "liCalendar",
  "version": "1.0.0",
  "identifier": "pro.softsoft.li-calendar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "removeUnusedCommands": true
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "松鼠日历",
        "width": 800,
        "height": 600,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "publisher": "softsoft.pro",
    "category": "Utility",
    "shortDescription": "松鼠日历",
    "longDescription": "松鼠日历",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
